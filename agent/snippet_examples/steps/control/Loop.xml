<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="71" name="Loop">
    <Restore state="False"/>
    <FlushType value="Always"/>
  </Step>
</fmxmlsnippet>
<!-- FlushType value: "Always" (default, flush all cached relationships) | "Minimum" (flush only one relationship away) | "Defer" (wait until loop exits to flush). -->
<!-- Exit via Exit Loop If step or Go to Record/Request/Page with Exit after last option. -->
<!-- Requires a matching End Loop step. -->
