<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="164" name="Perform Script on Server">
    <WaitForCompletion state="True"/>
    <Calculation><![CDATA[$optional_parameter]]></Calculation>
    <Script id="0" name=""/>
  </Step>
</fmxmlsnippet>
<!-- WaitForCompletion state (HR: "Wait for completion"): "True" → "On" pauses client until server script completes (required to capture Get(ScriptResult) or Get(LastError)). "False" → "Off" continues immediately. -->
<!-- Specified: From list — use <Script id="0" name=""/> with no <Calculated>. -->
<!-- Specified: By name — use <Calculated><Calculation><![CDATA["script_name"]]></Calculation></Calculated> before <WaitForCompletion>; omit <Script>. -->
<!-- Optional: Calculation (HR: "Parameter"). Omit the element entirely if no parameter is needed. -->
<!-- The current file must be hosted on FileMaker Server or FileMaker Cloud. -->
<!-- Avoid deadlocks or infinite loops when server-side scripts call other server-side scripts. -->
<!-- See https://help.claris.com/en/pro-help/content/perform-script-on-server.html -->
