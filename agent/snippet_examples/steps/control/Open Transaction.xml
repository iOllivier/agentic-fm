<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="205" name="Open Transaction">
    <Option state="False"/>
    <ESSForceCommit state="False"/>
    <SkipAutoEntry state="False"/>
    <Restore state="False"/>
  </Step>
</fmxmlsnippet>
<!-- SkipAutoEntry state: "True" shows "Skip auto-enter options" in HR. "False" omits it. -->
<!-- Option state: "True" shows "Skip data entry validation" in HR. "False" omits it. -->
<!-- ESSForceCommit state: "True" shows "Override ESS locking conflicts" in HR. "False" omits it. -->
<!-- Restore state: "True"/"False" — not shown in HR in any known configuration. -->
<!-- XML element order: Option, ESSForceCommit, SkipAutoEntry, Restore (differs from HR display order). -->
<!-- Requires a matching Commit Transaction step. -->
