<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="210" name="Perform Script on Server with Callback">
    <CallbackScriptState value="Continue"/>
    <Calculation><![CDATA[$optional_parameter]]></Calculation>
    <Script id="0" name=""/>
    <CallbackScript>
      <ScriptName id="0" name=""/>
      <ScriptParameter>
        <Calculation><![CDATA[$optional_parameter]]></Calculation>
      </ScriptParameter>
    </CallbackScript>
  </Step>
</fmxmlsnippet>
<!-- CallbackScriptState value (HR: "State"): "Continue" | "Halt" | "Exit" | "Resume" | "Pause". -->
<!-- Specified: From list — use <Script id="0" name=""/> with no <Calculated>. -->
<!-- Specified: By name — use <Calculated><Calculation/></Calculated> before <CallbackScriptState>; omit <Script>. -->
<!-- Optional: Calculation (HR: "Parameter") for the main server script. Always optional regardless of other settings. -->
<!-- Optional: CallbackScript containing <ScriptName id="0" name=""/> and optional <ScriptParameter><Calculation/></ScriptParameter> for the callback's parameter. -->
<!-- If CallbackScript is omitted, this step behaves like Perform Script on Server. -->
<!-- The callback script's parameter Calculation is evaluated when the callback runs on the client, not when the server script starts. Avoid Get(ScriptParameter) and Get(ScriptResult); use constants, global fields, or global variables instead. -->
<!-- The current file must be hosted on FileMaker Server or FileMaker Cloud. -->
<!-- See https://help.claris.com/en/pro-help/content/perform-script-on-server-callback.html -->
