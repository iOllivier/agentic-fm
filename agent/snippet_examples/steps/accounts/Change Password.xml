<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="83" name="Change Password">
    <NoInteract state="False"/>
    <OldPassword>
      <Calculation><![CDATA["old"]]></Calculation>
    </OldPassword>
    <NewPassword>
      <Calculation><![CDATA["new"]]></Calculation>
    </NewPassword>
  </Step>
</fmxmlsnippet>
<!-- NoInteract state: "True" suppresses dialog and uses the literal/calculated passwords. "False" shows the Change Password dialog. -->
<!-- Required: OldPassword, NewPassword (when NoInteract is "True"). -->
<!-- Only works with FileMaker file accounts. Other account types and Guest return error 3. -->
<!-- Users must have password change privileges, or the script must have Grant Full Access Privileges enabled. -->
<!-- Without Set Error Capture: users get 5 attempts. With Set Error Capture on: users get 1 attempt. -->
<!-- See https://help.claris.com/en/pro-help/content/change-password.html -->
