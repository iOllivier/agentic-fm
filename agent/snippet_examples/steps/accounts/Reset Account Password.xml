<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="136" name="Reset Account Password">
    <ChgPwdOnNextLogin value="True"/>
    <AccountName>
      <Calculation><![CDATA["account name"]]></Calculation>
    </AccountName>
    <Password>
      <Calculation><![CDATA["password"]]></Calculation>
    </Password>
  </Step>
</fmxmlsnippet>
<!-- ChgPwdOnNextLogin value: "True" forces password change on next login. "False" does not. -->
<!-- Required: AccountName, Password (new password). -->
<!-- Optional: ChgPwdOnNextLogin. -->
<!-- Only works with FileMaker file accounts. -->
<!-- Requires the Full Access privilege set to run (or Grant Full Access Privileges on the script). -->
<!-- No dialog is displayed; the password is reset immediately. -->
<!-- Use multiple occurrences of this step to reset multiple accounts in a single script. -->
<!-- See https://help.claris.com/en/pro-help/content/reset-account-password.html -->
