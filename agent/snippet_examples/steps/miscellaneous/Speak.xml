<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="66" name="Speak">
    <Calculation><![CDATA["text_to_speak"]]></Calculation>
    <SpeechOptions WaitForCompletion="True" VoiceName="Daria" VoiceId="2769835375" VoiceCreator="4242"/>
  </Step>
</fmxmlsnippet>
<!-- SpeechOptions attributes: WaitForCompletion ("True" waits until speech completes before continuing to next script step; "False" continues immediately), VoiceName (macOS voice name string, e.g. "Daria", "Ellen", "Alex"), VoiceId (numeric voice identifier), VoiceCreator (numeric voice creator identifier). -->
<!-- VoiceName, VoiceId, and VoiceCreator correspond to macOS system voices. The full list of available voices and their IDs can be obtained via the macOS say command: say -v '?' -->
<!-- Required: Calculation (text to be spoken; can be literal text or calculated text). -->
<!-- Optional: SpeechOptions (voice selection and wait behavior). -->
<!-- Produces speech from text using specified voice synthesizer. -->
<!-- Can enter literal text string or use calculation to create text to be spoken. -->
<!-- Can specify which voice synthesizer to use and whether to wait for speech completion. -->
<!-- If database opened on non-speaking computer: script can be edited but only default voice synthesizer available; Speak steps not executed when script is run. -->
<!-- macOS only. Not supported on Go, WebDirect, Server, Cloud, Data API, or CWP. -->
<!-- See https://help.claris.com/en/pro-help/content/speak-os-x.html -->
