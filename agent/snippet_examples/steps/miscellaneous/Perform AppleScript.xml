<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="67" name="Perform AppleScript">
    <ContentType value="Calculation"/>
    <Calculation><![CDATA["tell application \"Notes\" to open"]]></Calculation>
  </Step>
</fmxmlsnippet>
<!-- ContentType value: "Calculation" | "Text". -->
<!-- "Calculation": uses <Calculation> CDATA; compiled each time the step executes. -->
<!-- "Text": uses <Text>literal AppleScript</Text> instead of <Calculation>; compiled once when authored; up to 30,000 characters; indenting not supported. -->
<!-- Required: ContentType. Either Calculation or Text must be present depending on ContentType. -->
<!-- To receive Apple events, privilege set must have fmextscriptaccess extended privilege enabled. -->
<!-- macOS only. On Windows, step is ignored and generates a capturable error code. -->
<!-- Not supported on Go, WebDirect, Server, Cloud, Data API, or CWP. -->
<!-- See https://help.claris.com/en/pro-help/content/perform-applescript-os-x.html -->
