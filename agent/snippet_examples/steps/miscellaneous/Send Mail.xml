<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="63" name="Send Mail">
    <NoInteract state="True"/>
    <Attachment>
      <UniversalPathList>$attachmentFilePathList</UniversalPathList>
    </Attachment>
    <To UseFoundSet="False">
      <Calculation><![CDATA[$to]]></Calculation>
    </To>
    <Cc UseFoundSet="False">
      <Calculation><![CDATA[$cc]]></Calculation>
    </Cc>
    <Bcc UseFoundSet="False">
      <Calculation><![CDATA[$bcc]]></Calculation>
    </Bcc>
    <Subject>
      <Calculation><![CDATA[$subject]]></Calculation>
    </Subject>
    <Message>
      <Calculation><![CDATA[$message]]></Calculation>
    </Message>
    <SMTPNameDescription>
      <Calculation><![CDATA[$name]]></Calculation>
    </SMTPNameDescription>
    <SMTPEmailAddress>
      <Calculation><![CDATA[$from]]></Calculation>
    </SMTPEmailAddress>
    <SMTPReplyAddress>
      <Calculation><![CDATA[$replyTo]]></Calculation>
    </SMTPReplyAddress>
    <SMTPServer>
      <Calculation><![CDATA[$smtp]]></Calculation>
    </SMTPServer>
    <SMTPPort>
      <Calculation><![CDATA[587]]></Calculation>
    </SMTPPort>
    <SMTPUserName>
      <Calculation><![CDATA[$username]]></Calculation>
    </SMTPUserName>
    <SMTPPassword>
      <Calculation><![CDATA[$password]]></Calculation>
    </SMTPPassword>
    <OAuthNameDescription>
      <Calculation><![CDATA[$name]]></Calculation>
    </OAuthNameDescription>
    <OAuthEmailAddress>
      <Calculation><![CDATA[$from]]></Calculation>
    </OAuthEmailAddress>
    <OAuthReplyAddress>
      <Calculation><![CDATA[$replyTo]]></Calculation>
    </OAuthReplyAddress>
    <OAuthUserID>
      <Calculation><![CDATA[$adminUserEmail]]></Calculation>
    </OAuthUserID>
    <OAuthAccountEmail>
      <Calculation><![CDATA[$serviceAccountEmail]]></Calculation>
    </OAuthAccountEmail>
    <OAuthPrivateKey>
      <Calculation><![CDATA[$privateKey]]></Calculation>
    </OAuthPrivateKey>
    <MultipleEmails state="False"/>
    <SendViaSMTP state="False"/>
    <SendViaOAuthAuthentication state="True"/>
    <SMTPEncryptionType type="SMTPEncryptionTLS"/>
    <SMTPAuthenticationType type="SMTPAuthenticationPlain"/>
    <OAuthProvider type="OAuthProviderGoogle"/>
  </Step>
</fmxmlsnippet>
<!-- NoInteract state: "True" suppresses the composed email dialog (email placed in outbox). "False" leaves composed message open for review. -->
<!-- MultipleEmails state: "True" sends one message per record in found set. "False" sends one message using data from current record. -->
<!-- SendViaSMTP state: "True" sends via SMTP server. "False" does not use SMTP. -->
<!-- SendViaOAuthAuthentication state: "True" sends via OAuth 2.0. "False" does not use OAuth. -->
<!-- To/Cc/Bcc UseFoundSet attribute: "True" collects addresses across found set. "False" uses single value. -->
<!-- SMTPEncryptionType type: "SMTPEncryptionNone" | "SMTPEncryptionTLS" | "SMTPEncryptionSSL" -->
<!-- SMTPAuthenticationType type: "SMTPAuthenticationNone" | "SMTPAuthenticationPlain" -->
<!-- OAuthProvider type: "OAuthProviderGoogle" | "OAuthProviderMicrosoft" -->
<!-- Microsoft OAuth requires additional fields (add after OAuthPrivateKey):
  <OAuthPrincipalName><Calculation><![CDATA[$principalName]]></Calculation></OAuthPrincipalName>
  <OAuthTenantID><Calculation><![CDATA[$tenantId]]></Calculation></OAuthTenantID>
  <OAuthClientID><Calculation><![CDATA[$clientId]]></Calculation></OAuthClientID>
  <OAuthClientSecret><Calculation><![CDATA[$clientSecret]]></Calculation></OAuthClientSecret>
-->
<!-- Optional: To, Cc, Bcc, Subject, Message, Attachment (UniversalPathList file paths). -->
<!-- Optional SMTP fields: SMTPNameDescription, SMTPEmailAddress, SMTPReplyAddress, SMTPServer, SMTPPort, SMTPUserName, SMTPPassword. -->
<!-- Optional OAuth fields (Google): OAuthNameDescription, OAuthEmailAddress, OAuthReplyAddress, OAuthUserID, OAuthAccountEmail, OAuthPrivateKey. -->
<!-- Optional OAuth fields (Microsoft, in addition to Google fields): OAuthPrincipalName, OAuthTenantID, OAuthClientID, OAuthClientSecret. -->
<!-- Multiple email addresses in To/Cc/Bcc separated by carriage return or semicolon. -->
<!-- Email application mode: set SendViaSMTP="False" and SendViaOAuthAuthentication="False"; omit SMTP/OAuth fields. -->
<!-- See https://help.claris.com/en/pro-help/content/send-mail.html -->
