<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="167" name="Refresh Object">
    <ObjectName>
      <Calculation><![CDATA[$object]]></Calculation>
    </ObjectName>
    <Repetition>
      <Calculation><![CDATA[1]]></Calculation>
    </Repetition>
  </Step>
</fmxmlsnippet>
<!-- Required: ObjectName (named object on current layout). -->
<!-- Optional: Repetition (specifies which field repetition to refresh; defaults to 1; ignored if object is not a field; if calculation returns zero or doesn't exist, all repetitions are refreshed). -->
<!-- Updates the object's contents, conditional formatting, and visibility state. -->
<!-- Does not support repetition numbers when updating visibility state of an object with a hidden condition. -->
<!-- If object is in a portal, updates the object in every visible portal row. -->
<!-- To update all objects in current window, use Refresh Window script step. -->
<!-- Not supported on Server, Cloud, Data API, or CWP. -->
<!-- See https://help.claris.com/en/pro-help/content/refresh-object.html -->
