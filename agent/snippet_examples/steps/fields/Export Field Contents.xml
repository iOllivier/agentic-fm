<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="132" name="Export Field Contents">
    <CreateDirectories state="True"/>
    <AutoOpen state="False"/>
    <CreateEmail state="False"/>
    <UniversalPathList>$path</UniversalPathList>
    <Field table="" id="0" name=""/>
  </Step>
</fmxmlsnippet>
<!-- CreateDirectories state: "True" creates folders (HR: Create folders: On). "False" does not (HR: Create folders: Off). -->
<!-- AutoOpen state: "True" opens the exported file (HR: Automatically open shown). "False" does not (HR: omitted). -->
<!-- CreateEmail state: "True" creates a new email with attachment (HR: Create email shown). "False" does not (HR: omitted). -->
<!-- Field: target field to export. Supports repetition attribute (HR: Field[rep]). If omitted, exports the current field. -->
<!-- Optional: UniversalPathList (output file path), CreateDirectories, AutoOpen, CreateEmail. If no path is specified, the user is prompted. -->
<!-- Text fields are exported as UTF-16 (use TextEncode to convert first). In FileMaker Go, text is exported as UTF-8. -->
<!-- See https://help.claris.com/en/pro-help/content/export-field-contents.html -->
