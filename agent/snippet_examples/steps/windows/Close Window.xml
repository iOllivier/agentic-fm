<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="121" name="Close Window">
    <LimitToWindowsOfCurrentFile state="True"/>
    <Window value="ByName"/>
    <Name>
      <Calculation><![CDATA[]]></Calculation>
    </Name>
  </Step>
</fmxmlsnippet>
<!-- LimitToWindowsOfCurrentFile state: "True" restricts matches to current file (Current file only option). "False" matches all available FileMaker Pro files. -->
<!-- Window enumeration: "ByName" specifies which window to close by name; "Current" closes the active window. -->
<!-- Closes currently active window or any other window by name. -->
<!-- Closing last window of file closes the file and halts execution of current script. -->
<!-- In Windows: FileMaker Pro exits when no other windows are open or hidden. -->
<!-- See https://help.claris.com/en/pro-help/content/close-window.html -->
