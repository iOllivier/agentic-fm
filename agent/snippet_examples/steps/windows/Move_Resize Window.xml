<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="119" name="Move/Resize Window">
    <LimitToWindowsOfCurrentFile state="True"/>
    <Window value="ByName"/>
    <Name>
      <Calculation><![CDATA["window name"]]></Calculation>
    </Name>
    <Height>
      <Calculation><![CDATA[400 // Pixels]]></Calculation>
    </Height>
    <Width>
      <Calculation><![CDATA[600 // Pixels]]></Calculation>
    </Width>
    <DistanceFromTop>
      <Calculation><![CDATA[100 // Pixels from top of screen]]></Calculation>
    </DistanceFromTop>
    <DistanceFromLeft>
      <Calculation><![CDATA[100 // Pixels from left of screen]]></Calculation>
    </DistanceFromLeft>
  </Step>
</fmxmlsnippet>
<!-- Window value: "ByName" | "Current". "Current" selects the foreground window; omit Name when using Current. -->
<!-- LimitToWindowsOfCurrentFile state: "True" restricts to current file. "False" matches all open FileMaker files. HR label: "Current file". -->
<!-- HR label for DistanceFromTop: "Top". HR label for DistanceFromLeft: "Left". -->
<!-- Optional: Name, Height, Width, DistanceFromTop, DistanceFromLeft. Omitted dimension/position values default to the window's current values. -->
<!-- Minimum height/width depend on the OS. Maximum height/width depend on screen resolution. -->
<!-- Supported on Pro. Partial support on Go (cards only) and WebDirect (cards only). Not supported on Server, Cloud, Data API, or CWP. -->
<!-- See https://help.claris.com/en/pro-help/content/move-resize-window.html -->
