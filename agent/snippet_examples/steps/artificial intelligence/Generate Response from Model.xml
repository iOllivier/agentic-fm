<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="220" name="Generate Response from Model">
    <Option state="True"/>
    <SelectAll state="True"/>
    <Stream state="True"/>
    <Set state="True"/>
    <LinkAvail state="True"/>
    <Restore state="True"/>
    <UniversalPathList type="Reference"/>
    <Text/>
    <Field table="" id="0" name=""/>
    <LLMRequestWithTools>
      <AccountName>
        <Calculation><![CDATA["account_name"]]></Calculation>
      </AccountName>
      <Model>
        <Calculation><![CDATA["model"]]></Calculation>
      </Model>
      <UserPrompt>
        <Calculation><![CDATA["prompt"]]></Calculation>
      </UserPrompt>
      <Instructions>
        <Calculation><![CDATA["instructions"]]></Calculation>
      </Instructions>
      <Field type="Messages">$variable</Field>
      <SlidingWindowVariable>$variable</SlidingWindowVariable>
      <SlidingWindowMessageCount>
        <Calculation><![CDATA[1]]></Calculation>
      </SlidingWindowMessageCount>
      <SlidingWindowVariableRepetition>
        <Calculation><![CDATA[2]]></Calculation>
      </SlidingWindowVariableRepetition>
      <ToolDefinitions>
        <Calculation><![CDATA["tool_definitions"]]></Calculation>
      </ToolDefinitions>
      <Field type="ToolCalls">$variable</Field>
      <Temperature>
        <Calculation><![CDATA["temperature"]]></Calculation>
      </Temperature>
      <Parameters>
        <Calculation><![CDATA["parameters"]]></Calculation>
      </Parameters>
      <WebScript>
        <ObjectName>
          <Calculation><![CDATA[$object]]></Calculation>
        </ObjectName>
        <FunctionName>
          <Calculation><![CDATA["jsFunctionName"]]></Calculation>
        </FunctionName>
        <WebScriptParameters Count="1">
          <P>
            <Calculation><![CDATA["jsParameter"]]></Calculation>
          </P>
        </WebScriptParameters>
      </WebScript>
    </LLMRequestWithTools>
  </Step>
</fmxmlsnippet>
<!-- All named calcs are inside <LLMRequestWithTools>. -->
<!-- Boolean flags (siblings): Set=Agentic mode, Stream=Stream flag, SelectAll=ToolDefinitions present, Option=Parameters present, LinkAvail=Messages present, Restore=WebScript present. -->
<!-- Set state: "True" enables agentic mode (HR: Agentic mode shown). -->
<!-- Stream state: "True" enables streaming (HR: Stream shown). -->
<!-- Response: <Field> sibling of LLMRequestWithTools. Dual format: field ref (table/id/name) or variable (<Field>$variable</Field> with <Text/>). Supports repetition. HR: Response. -->
<!-- Tool Calls from Model: <Field type="ToolCalls"> inside LLMRequestWithTools. Variable only. HR: Tool Calls from Model. -->
<!-- Messages: <Field type="Messages"> inside LLMRequestWithTools. Variable only. HR: Messages. -->
<!-- Save Message History To: <SlidingWindowVariable> (variable name) + <SlidingWindowVariableRepetition><Calculation> (repetition, shown as [rep] in HR). HR: Save Message History To. -->
<!-- Message History Count: <SlidingWindowMessageCount><Calculation>. HR: Message History Count. -->
<!-- WebScript: contains ObjectName (HR: Web Viewer), FunctionName (HR: Function Name), and optional WebScriptParameters with Count and P/Calculation children. -->
<!-- UniversalPathList: type="Embedded" for basic, type="Reference" when Temperature present. -->
