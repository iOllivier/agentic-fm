<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="74" name="Go to Related Record">
    <Option state="False"/>
    <MatchAllRecords state="False"/>
    <ShowInNewWindow state="False"/>
    <Restore state="True"/>
    <LayoutDestination value="SelectedLayout"/>
    <NewWndStyles Style="Document" Close="Yes" Minimize="Yes" Maximize="Yes" Resize="Yes" Styles="3606018"/>
    <Table id="0" name=""/>
    <Layout id="0" name=""/>
    <Animation value="None"/>
  </Step>
</fmxmlsnippet>
<!-- Option state: "True" shows only related records (Show only related records). "False" does not filter. -->
<!-- MatchAllRecords state: "True" matches all records in current found set (Match found set). "False" matches current record only. -->
<!-- ShowInNewWindow state: "True" shows related records in new window (New window). "False" shows in current window. -->
<!-- LayoutDestination value: "CurrentLayout" | "SelectedLayout" | "LayoutNameByCalc" | "LayoutNumberByCalc" | "UseExternalTableLayouts" -->
<!-- NewWndStyles attributes: Style ("Document" | "Floating" | "Dialog" | "Card"), Close/Minimize/Maximize/Resize ("Yes" | "No"), DimParentWindow/Toolbars/MenuBar ("Yes" | "No"), Styles (numeric bitmask). Only applies when ShowInNewWindow is True. -->
<!-- Animation value: "SlideFromLeft" | "SlideFromRight" | "SlideFromBottom" | "SlideToLeft" | "SlideToRight" | "SlideToBottom" | "FlipFromLeft" | "FlipFromRight" | "ZoomIn" | "ZoomOut" | "CrossDissolve". FileMaker Go only. -->
<!-- Required: Table (source relationship to go to). -->
<!-- Optional: Layout, Option (Show only related records), MatchAllRecords (Match found set), ShowInNewWindow (New window), Animation (Go only), NewWndStyles, Name/Height/Width/DistanceFromTop/DistanceFromLeft (window params when ShowInNewWindow). -->
<!-- Goes to current related record(s) in related table. -->
<!-- Example: from Invoices table viewing specific invoice, button set to Go to Related Record [Customers] determines which customer record current invoice is related to and goes to that record in Customers table. If record not in Customers found set, script can perform find to make record current. -->
<!-- Works with portal rows: if used from active portal row and portal's table is related table, related record in that table is made current. If portal's table is not related table, first related record in found set is made current. -->
<!-- With external file: opens file containing external table and goes to specified external layout if selected. -->
<!-- If related records cannot be found: remains on current layout; returns error code (capturable with Get(LastError)). -->
<!-- If table occurrence has no relationship or layout doesn't refer to correct table occurrence: displays error message and continues with next script step. -->
<!-- If no related records or no record in active portal row: might produce unexpected results. Use IsEmpty function to check before using. -->
<!-- If "Allow creation of records in this table via this relationship" enabled and Go to Related Record performed from empty portal row: might produce unexpected results. -->
<!-- When opening new window: doesn't activate OnFirstWindowOpen or OnWindowOpen triggers (triggered script may not go to desired layout/view). To run script after opening new window, add Perform Script as next step. To bring new window to front, add Select Window step. -->
<!-- Sort order not maintained if related records are in external file. -->
<!-- If performed in context of filtered portal's row with Show only related records option set: only filtered records are in new found set. However, if focus not in filtered portal's row, new found set can include all related records, not just filtered records. -->
<!-- Animation option: FileMaker Go only; can only use for selected window; cannot use for navigating between records via slider or status toolbar buttons. -->
<!-- Partial support on Pro (no animation), WebDirect (no animation), Server (no animation), Cloud (no animation), Data API (no animation), and CWP (no animation). -->
<!-- See https://help.claris.com/en/pro-help/content/go-to-related-record.html -->