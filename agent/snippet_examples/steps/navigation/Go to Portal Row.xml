<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="99" name="Go to Portal Row">
    <NoInteract state="True"/>
    <SelectAll state="False"/>
    <RowPageLocation value="ByCalculation"/>
    <Calculation><![CDATA[1]]></Calculation>
  </Step>
</fmxmlsnippet>
<!-- RowPageLocation value: "First" | "Last" | "Previous" | "Next" | "ByCalculation" -->
<!-- Exit state: "True" exits after last/first row (only applies when RowPageLocation is "Previous" or "Next"). "False" does not exit. -->
<!-- NoInteract state: "True" suppresses dialog (With dialog: Off). "False" shows dialog for user to confirm row number. Only applies to "ByCalculation". -->
<!-- SelectAll state: "True" selects entire portal row (Select). "False" only one field in portal is active. -->
<!-- Optional: Exit (with Previous/Next only), Calculation (for ByCalculation option). -->
<!-- Navigates among rows in active portal. When no portal is active, uses first portal in layout stacking order. -->
<!-- Tries to keep same field selected when changing rows. If no field in portal is selected, selects first field it can enter. -->
<!-- Example: if third field in second portal row is selected, Go to Portal Row [Next] goes to third field in third portal row. -->
<!-- In portal displaying records from current table: has same result as Go to Record/Request/Page. -->
<!-- In WebDirect: cursor moves next to specified row but row is not selected. -->
<!-- Server-side scripts, Data API, and CWP: do not support ByCalculation option. -->
<!-- When performed on server: commits current record. -->
<!-- Partial support on WebDirect (row not selected), Server (no ByCalculation, commits record), Cloud (no ByCalculation, commits record), Data API (no ByCalculation), and CWP (no ByCalculation). -->
<!-- See https://help.claris.com/en/pro-help/content/go-to-portal-row.html -->
