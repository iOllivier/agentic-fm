<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="228" name="Go to List of Records">
    <ShowInNewWindow state="False"/>
    <LayoutDestination value="CurrentLayout"/>
    <RowList>
      <Calculation><![CDATA["calc"]]></Calculation>
    </RowList>
    <NewWndStyles Style="Document" Close="Yes" Minimize="Yes" Maximize="Yes" Resize="Yes" Styles="3606018"/>
  </Step>
</fmxmlsnippet>
<!-- ShowInNewWindow state: "True" opens in new window (HR: New window). "False" uses current window (HR: Animation option available). Mutually exclusive with Animation. -->
<!-- LayoutDestination: see animation-enums.md. "CurrentLayout" (HR: <Current Layout>) | "SelectedLayout" + <Layout id="" name=""/> | "LayoutNameByCalc" + <Layout><Calculation> | "LayoutNumberByCalc" + <Layout><Calculation>. -->
<!-- RowList: required. List of record IDs (list of values, JSON array, or JSON array of objects with recordId key). -->
<!-- Animation: see animation-enums.md for all values. Only when ShowInNewWindow=False. FileMaker Go only. -->
<!-- New window mode: when ShowInNewWindow=True, adds Name, Height, Width, DistanceFromTop, DistanceFromLeft calc siblings. See window-enums.md for NewWndStyles attributes and window types. -->
<!-- See https://help.claris.com/en/pro-help/content/go-to-list-of-records.html -->
