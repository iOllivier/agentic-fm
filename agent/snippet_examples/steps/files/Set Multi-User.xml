<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="84" name="Set Multi-User">
    <MultiUser value="True"/>
  </Step>
</fmxmlsnippet>
<!-- MultiUser value: "True" (On, allows network access) | "OnHidden" (On Hidden, allows access but hides from host file list) | "False" (Off, disallows network access) -->
<!-- FileMaker Pro only; not supported on Go, WebDirect, Server, Cloud, Data API, or CWP. -->
