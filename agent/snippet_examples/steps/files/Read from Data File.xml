<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="193" name="Read from Data File">
    <DataSourceType value="3"/>
    <Calculation><![CDATA[$fileID]]></Calculation>
    <Text/>
    <Field>$variable</Field>
    <Count>
      <Calculation><![CDATA[1024]]></Calculation>
    </Count>
  </Step>
</fmxmlsnippet>
<!-- DataSourceType value: "1" (UTF-16) | "2" (UTF-8) | "3" (Bytes) -->
<!-- Required: Calculation (numeric file ID of an open data file). -->
<!-- Optional: Count (bytes for UTF-8/Bytes, or code units for UTF-16; if omitted, reads entire file), Target. -->
<!-- HR label for Count is "Amount (bytes)" for UTF-8 and Bytes; "Amount" (no unit) for UTF-16. -->
<!-- Target: Field element uses <Field table="" id="0" name=""/> for a field, or <Field>$variable</Field> with a <Text/> sibling for a variable. Variable repetition uses <Field repetition="2">$variable</Field>. -->
<!-- For Bytes: if target is a variable or container field, data is stored as container data with the source filename. -->
<!-- Reads from the current read-write position. Use Set Data File Position to change it. -->
<!-- Maximum 64 MB per read. For larger files, read in chunks. Best performance at 64 KB or less. -->
<!-- When reading Unicode from a portion of a file, partial multi-code-unit characters may result; safer to read entire file unless code points per character are known. -->
<!-- See https://help.claris.com/en/pro-help/content/read-from-data-file.html -->
