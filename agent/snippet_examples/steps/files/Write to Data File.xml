<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="192" name="Write to Data File">
    <AppendLineFeed state="True"/>
    <DataSourceType value="2"/>
    <Calculation><![CDATA[$fileID]]></Calculation>
    <Text/>
    <Field>$variable</Field>
  </Step>
</fmxmlsnippet>
<!-- DataSourceType value: "1" (UTF-16 little endian) | "2" (UTF-8). Ignored for container data (written as binary). -->
<!-- AppendLineFeed state: "True" adds a line feed character after the written data. "False" does not. -->
<!-- Required: Calculation (numeric file ID of an open data file). -->
<!-- Data source: Field element uses <Field table="" id="0" name=""/> for a field, or <Field>$variable</Field> with sibling <Text/> for a variable. -->
<!-- Field repetition: add repetition="n" attribute to Field for a specific repetition of a repeating field (e.g., <Field table="T" id="1" repetition="2" name="F"/>). -->
<!-- <Text/> empty element: present as sibling of Field when data source is a variable; omit when data source is a field reference. -->
<!-- Data at the current read-write position is overwritten. Use Set Data File Position to change it. -->
<!-- Maximum 64 MB per write. For larger data, write in chunks. Best performance at 64 KB or less. -->
<!-- See https://help.claris.com/en/pro-help/content/write-to-data-file.html -->
