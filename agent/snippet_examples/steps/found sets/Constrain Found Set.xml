    <Option state="True"/>
    <Restore state="True"/>
    <Query>
      <RequestRow operation="Include">
        <Criteria>
          <Field table="" id="0" name=""/>
          <Text>$query</Text>
        </Criteria>
      </RequestRow>
    </Query>
